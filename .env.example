# ============================================================
# ChorusGate — Environment Variables
# ============================================================
# Copy to .env (gitignored). ~/.gateway/.env also supported.
# Shell env vars always take precedence.
#
# 完整文档: docs/feature-mcp-server.md / README.md

# ---- Required — Slack Tokens ------------------------------------------------

# App-Level Token for Socket Mode (xapp-..., scope: connections:write)
SLACK_APP_TOKEN=xapp-...

# Bot User OAuth Token for Web API calls (xoxb-...)
SLACK_BOT_TOKEN=xoxb-...

# ---- Agent Provider ----------------------------------------------------------

# Agent runtime: "claude" (默认) | "claude-stream" | "codex"
# GATEWAY_PROVIDER=claude

# Claude 模式: "legacy" (默认, 单向 stdin) | "stream" (双向 stream-json)
# GATEWAY_CLAUDE_MODE=legacy

# Slash command 前缀 (默认 "cc")
# GATEWAY_COMMAND_PREFIX=cc

# 工作目录 — spawned claude/codex 从这里运行 (默认 process.cwd())
# GATEWAY_CLAUDE_CWD=E:\my_project

# Claude / Codex 二进制路径
# CLAUDE_BIN=claude
# CODEX_BIN=codex

# 权限模式: "bypassPermissions" (默认) | "default" | "acceptEdits"
# CLAUDE_PERMISSION_MODE=bypassPermissions

# ---- Multi-Profile (v3) ------------------------------------------------------

# 多 Slack App 同时运行。逗号分隔 profile ID。
# 不设 = 单 "default" profile，从上面 SLACK_BOT_TOKEN / SLACK_APP_TOKEN 取值（向后兼容）
# GATEWAY_PROFILES=cc,codex

# Per-profile tokens（GATEWAY_PROFILES 存在时生效，<ID> 需大写）
# SLACK_BOT_TOKEN_CC=xoxb-cc-...
# SLACK_APP_TOKEN_CC=xapp-cc-...
# SLACK_BOT_TOKEN_CODEX=xoxb-codex-...
# SLACK_APP_TOKEN_CODEX=xapp-codex-...

# Per-profile provider 和工作目录
# GATEWAY_PROVIDER_CC=claude
# GATEWAY_CWD_CC=E:\project-a
# GATEWAY_PROVIDER_CODEX=codex
# GATEWAY_CWD_CODEX=E:\project-b

# Per-profile command prefix（slash 命令前缀，默认等于 profile ID）
# GATEWAY_COMMAND_PREFIX_CC=cc
# GATEWAY_COMMAND_PREFIX_CODEX=cx

# ---- Gateway Daemon ----------------------------------------------------------

# 最大并发 spawned processes (默认 3)
# GATEWAY_MAX_CONCURRENT=3

# 新对话超时 ms (默认 180000 = 3min)
# GATEWAY_REPLY_TIMEOUT_MS=180000

# 续轮超时 ms (默认 360000 = 6min)
# GATEWAY_REPLY_TIMEOUT_MS_LONG=360000

# Session 作用域: "channel" (频道共享, 默认) | "thread" (每线程独立)
# GATEWAY_SESSION_SCOPE=channel

# Idle session mapping 清理间隔 ms (默认 86400000 = 24h)
# GATEWAY_SESSION_IDLE_MS=86400000

# 实时进度提示: 1 (开启, 默认) | 0 (关闭)
# GATEWAY_PROGRESS=1

# ---- Interactive Permissions (审批按钮) -------------------------------------

# 开启 Slack 审批按钮 (需 CLAUDE_PERMISSION_MODE ≠ bypassPermissions)
# GATEWAY_INTERACTIVE_PERMISSIONS=1

# ---- Gateway Interrupt -------------------------------------------------------

# 用户连续发消息时的处理: "interrupt" (打断当前, 默认) | "queue" (排队)
# GATEWAY_BUSY_MODE=interrupt

# ---- Trello MCP (可选) -------------------------------------------------------

# TRELLO_API_KEY=
# TRELLO_TOKEN=
