{
  "display_information": {
    "name": "ClaudeCodeApp",
    "description": "小克",
    "background_color": "#004492"
  },
  "features": {
    "bot_user": {
      "display_name": "ClaudeCodeApp",
      "always_online": true
    },
    "app_home": {
      "home_tab_enabled": true,
      "messages_tab_enabled": true,
      "messages_tab_read_only_enabled": false
    },
    "slash_commands": [
      {
        "command": "/cc_sessions",
        "url": "https://claudecode.local/slack/commands",
        "description": "列出本频道的 Claude Code 会话",
        "should_escape": false
      },
      {
        "command": "/cc_resume",
        "url": "https://claudecode.local/slack/commands",
        "description": "把本频道切换到某个会话",
        "usage_hint": "[N | session-uuid]",
        "should_escape": false
      },
      {
        "command": "/cc_new",
        "url": "https://claudecode.local/slack/commands",
        "description": "重置本频道会话（下条消息开新对话）",
        "should_escape": false
      },
      {
        "command": "/cc_current",
        "url": "https://claudecode.local/slack/commands",
        "description": "显示本频道当前绑定的会话",
        "should_escape": false
      },
      {
        "command": "/cchelp",
        "url": "https://claudecode.local/slack/commands",
        "description": "ClaudeCode 命令帮助",
        "should_escape": false
      }
    ]
  },
  "oauth_config": {
    "scopes": {
      "bot": [
        "app_mentions:read",
        "channels:history",
        "channels:join",
        "channels:read",
        "chat:write",
        "commands",
        "files:read",
        "groups:history",
        "groups:read",
        "im:history",
        "im:read",
        "im:write",
        "mpim:history",
        "reactions:read",
        "reactions:write",
        "users:read"
      ]
    }
  },
  "settings": {
    "event_subscriptions": {
      "bot_events": [
        "app_mention",
        "message.channels",
        "message.groups",
        "message.im",
        "reaction_added"
      ]
    },
    "interactivity": {
      "is_enabled": true
    },
    "org_deploy_enabled": false,
    "socket_mode_enabled": true,
    "token_rotation_enabled": false
  }
}
